<icecast>
  <location>Earth</location>
  <admin>admin@chillmatch.app</admin>

  <limits>
    <clients>100</clients>
    <sources>2</sources>
    <queue-size>524288</queue-size>
    <client-timeout>30</client-timeout>
    <header-timeout>15</header-timeout>
    <source-timeout>10</source-timeout>
    <burst-on-connect>1</burst-on-connect>
    <burst-size>65535</burst-size>
  </limits>

  <authentication>
    <source-password>RADIOBOSS_SOURCE_PASSWORD</source-password>
    <relay-password>relay_password_change_me</relay-password>
    <admin-user>admin</admin-user>
    <admin-password>ADMIN_PASSWORD_CHANGE_ME</admin-password>
  </authentication>

  <hostname>localhost</hostname>

  <listen-socket>
    <port>8000</port>
  </listen-socket>

  <mount type="normal">
    <mount-name>/stream</mount-name>
    <max-listeners>100</max-listeners>
    <dump-file>/tmp/stream-dump.ogg</dump-file>
    <stream-name>ChillMatch Radio</stream-name>
    <stream-description>ChillMatch vibes 24/7</stream-description>
    <stream-url>https://radio.chillmatch.app</stream-url>
    <genre>Chill</genre>
    <public>0</public>
  </mount>

  <fileserve>1</fileserve>

  <paths>
    <basedir>/usr/share/icecast2</basedir>
    <logdir>/var/log/icecast2</logdir>
    <webroot>/usr/share/icecast2/web</webroot>
    <adminroot>/usr/share/icecast2/admin</adminroot>
    <alias source="/" destination="/status.xsl"/>
  </paths>

  <logging>
    <accesslog>access.log</accesslog>
    <errorlog>error.log</errorlog>
    <loglevel>3</loglevel>
    <logsize>10000</logsize>
  </logging>

  <security>
    <chroot>0</chroot>
  </security>
</icecast>
